.env
.DS_Store
__pycache__/
*.pyc
.venv/
.claude/

# per-step state that must never be committed
**/checkpoints/
**/logs/
**/*.lock
~$*.xlsx

# auth state / cookies for browser automation
.orum_pipeline/
*_auth_state.json

# --- secrets that MUST never be committed (AUTHORIZATION_SPEC.md I40/I41/I42/I66/I67) ---
# nested .env files (root .env is above; provider API keys live in these)
**/.env
# W3ID/SSO login-flow screenshots — capture the seller's email in the login form
_login_debug/
**/_login_debug/
# Meetings backend: intercepted bearer-token caches + authenticated-page DOM dumps
**/browser_profile/
*_token.json
**/debug_*.html
**/debug_*.png
# ISC Aura bootstrap = a second plaintext copy of the Salesforce session cookie
aura_bootstrap.json
**/aura_bootstrap.json
# orphaned atomic-write temp copies of secret files (never GC'd on crash)
*.tmp
*.tmp[0-9]*
**/*.json.tmp*

# control files for login_capture.py's SAVE/RELOAD signaling + status polling
.orum_login_control/

# persisted dashboard preferences (e.g. default Salesloft cadence for Step 5 auto mode)
.orum_pipeline_state.json

# WatsonX Clone local demo state (regenerated at runtime)
.watsonx_identity.json
.mock_salesloft_state.json

# raw captured live-traffic debug dumps — contain real session tokens / IBM account data
ISC_Scraper_App/_internal/_gt_working_request.json

# stale compiled binary (PyInstaller build, predates current fixes per CONTEXT.md) —
# large and not useful in version control; source files are what matter
ISC_Scraper_App/ISC_Scraper

# generated data files (dated outputs + latest pointers + sidecar json) —
# regenerated by running the steps, so never version-controlled
ISC_Scraper_App/output/*.xlsx
ISC_Scraper_App/output/*.json
Account_Segmentation/output/*.xlsx
IBM_Scraper_App/output/*.xlsx
IBM_Scraper_App/output/*.json
IBM_Scraper_App/output/storage_raw/
Account_Tiering/output/*.xlsx
Call_Planning/output/*.xlsx
Call_Planning/output/*.json
ZoomInfo_Contact_Readiness/output/*.xlsx
Salesloft_Cadence_Readiness/output/*.xlsx
Bobby_AI_Emailer/output/*.xlsx
Bobby_AI_Emailer/output/*.json
Pipeline_Review/output/*.xlsx
Pipeline_Review/output/*.json
