# Shared credentials for Steps 2-5. Copy this file to `.env` at the repo root
# (never commit the real `.env` — see .gitignore) and fill in real values.
#
# Step 1 (ISC_Scraper_App) manages its own auth state separately — see
# ISC_Scraper_App/README.md — because it predates this shared convention and
# already has a working ~/.isc_scraper/auth_state.json bootstrap flow.

# --- Global ---
# TEST_MODE: "true" -> Step 2+ only process the fixed 5-account sample (see
# Account_Tiering/sample_selection.py) and Step 4/5 write to obviously-named
# test resources instead of production ZoomInfo lists / Salesloft cadences.
TEST_MODE=true

# --- ZoomInfo (browser automation, no API access) ---
# Persistent Playwright storage-state file, same idea as ISC's auth_state.json.
# First run opens a visible browser for you to log in once; subsequent runs
# reuse this file headlessly until it expires.
ZOOMINFO_AUTH_STATE_PATH=~/.orum_pipeline/zoominfo_auth_state.json
ZOOMINFO_BASE_URL=https://app.zoominfo.com

# --- Salesloft (browser automation, no API access) ---
SALESLOFT_AUTH_STATE_PATH=~/.orum_pipeline/salesloft_auth_state.json
SALESLOFT_BASE_URL=https://app.salesloft.com

# --- Rate / cost ceilings ---
# PLACEHOLDER — user confirmed "20" during initial scoping without specifying
# units. Treated conservatively as "pause after every 20 calls in a single run"
# for both ZoomInfo and Salesloft browser-automation steps. This is almost
# certainly too low for a real 700-account production run — confirm actual
# per-day/per-month quotas before running Step 2/4/5 at full scale, then edit
# these two numbers. Do not raise them without an explicit decision to do so.
ZOOMINFO_CALL_PAUSE_THRESHOLD=20
SALESLOFT_CALL_PAUSE_THRESHOLD=20

# --- Web signal search (Step 2) ---
# No paid API configured — signal_scraper.py uses general web search. If you
# later add a paid news/signal API, put its key here and wire it in following
# the same interface as the existing search backend.
# SIGNAL_SEARCH_API_KEY=

# --- Pipeline Review (Pipeline tab) ---
# The presaved ISC Forecast dashboard, the saved view to switch to, and the tab
# whose opportunity table is recreated on the Pipeline tab.
# PIPELINE_DASHBOARD_URL=            # direct URL; if empty the dashboard is found by name
PIPELINE_DASHBOARD_NAME=Forecast
PIPELINE_VIEW_NAME=Lanie Form
PIPELINE_TABLE_TAB=Deal List by Opportunity
# A Next Steps note older than this many days earns the ⚠ (shown next to the note).
PIPELINE_STALE_DAYS=7
# Capture the FULL deal list (scroll + "Load more"), and read each deal's Chatter.
PIPELINE_LOAD_ALL_ROWS=true
PIPELINE_FETCH_CHATTER=true
PIPELINE_MAX_CHATTER_POSTS=5
PIPELINE_CHATTER_TIME_BUDGET=240
# Name used to sign the BP follow-up email drafts.
# PIPELINE_SELLER_NAME=
# LIVE-WRITE GATE — leave UNSET. Set to 1 (and calibrate on ONE opportunity) only
# when the Chatter-post + Next-Step-overwrite write is ready to go live.
# PIPELINE_ENABLE_UPDATE=1

# --- Pipeline tab v2 (deal-list filters) ---
PIPELINE_DEFAULT_STATUSES=Open
PIPELINE_DEFAULT_GROUPINGS=Upside,Stretch
PIPELINE_SET_STATUS_FILTER=true
# PIPELINE_FORECAST_CATEGORY_MAP={"commit":"Call","best case":"Upside","pipeline":"Stretch"}

# --- Win-back (Pipeline tab v3) ---
PIPELINE_WINBACK_YEARS=5
