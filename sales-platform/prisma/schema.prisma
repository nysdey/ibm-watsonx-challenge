generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth (NextAuth) ──────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  repProfile    RepProfile?
  activities    Activity[]
  outreachPlans OutreachPlan[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Sales Platform ───────────────────────────────────────────────────────────

model SalesAccount {
  id              String    @id @default(cuid())
  companyName     String
  domain          String?
  industry        String?
  segment         String?   // SMB / Mid-Market / Enterprise
  tier            String?   // A / B / C / D
  priorityScore   Float?
  aiRationale     String?   @db.Text
  useCaseBucket   String?   // e.g. Security, Modernization, Cost Savings
  lastEnrichedAt  DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  contacts      Contact[]
  signals       Signal[]
  outreachPlans OutreachPlan[]
  activities    Activity[]

  @@unique([companyName, domain])
}

model Contact {
  id             String   @id @default(cuid())
  salesAccountId String
  name           String
  title          String?
  email          String?
  phone          String?
  linkedIn       String?
  source         String   @default("manual") // zoominfo | manual | csv
  personaFitScore Float?
  isItDirector   Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  salesAccount  SalesAccount   @relation(fields: [salesAccountId], references: [id], onDelete: Cascade)
  outreachPlans OutreachPlan[]
  activities    Activity[]
}

model Signal {
  id             String   @id @default(cuid())
  salesAccountId String
  type           String   // intent | install | news | lisn
  source         String   // zoominfo | lisn | install_base | web
  payload        Json
  score          Float?
  ingestedAt     DateTime @default(now())

  salesAccount SalesAccount @relation(fields: [salesAccountId], references: [id], onDelete: Cascade)
}

model RepProfile {
  id               String   @id @default(cuid())
  userId           String   @unique
  products         String[] // product slugs
  territory        String?
  industries       String[]
  toneFormality    Int      @default(3) // 1-5
  toneBrevity      Int      @default(3) // 1-5
  automationLevel  Int      @default(1) // 0-4
  exampleEmails    String[] @db.Text
  writingStyleNote String?  @db.Text
  notifyDigest     String   @default("daily") // daily | weekly | none
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Cadence {
  id                String @id @default(cuid())
  name              String
  useCaseBucket     String
  salesloftCadenceId String?
  description       String? @db.Text
  createdAt         DateTime @default(now())

  outreachPlans OutreachPlan[]
}

model OutreachPlan {
  id             String    @id @default(cuid())
  userId         String
  salesAccountId String
  contactId      String?
  cadenceId      String?
  actionType     String    // email | call | linkedin
  scheduledDate  DateTime
  status         String    @default("pending") // pending | approved | sent | skipped
  aiDraft        String?   @db.Text
  aiPromptLog    String?   @db.Text
  modelVersion   String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  salesAccount SalesAccount  @relation(fields: [salesAccountId], references: [id], onDelete: Cascade)
  contact      Contact?      @relation(fields: [contactId], references: [id])
  cadence      Cadence?      @relation(fields: [cadenceId], references: [id])
}

model Activity {
  id             String   @id @default(cuid())
  userId         String
  salesAccountId String
  contactId      String?
  type           String   // call | email | linkedin
  outcome        String?  // connected | voicemail | no_answer | replied | opened | clicked | bounced
  notes          String?  @db.Text
  salesloftId    String?
  timestamp      DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  salesAccount SalesAccount @relation(fields: [salesAccountId], references: [id], onDelete: Cascade)
  contact      Contact?     @relation(fields: [contactId], references: [id])
}

model KnowledgeBase {
  id        String   @id @default(cuid())
  product   String
  useCase   String
  title     String
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  action      String
  entity      String
  entityId    String?
  payload     Json?
  modelVersion String?
  promptHash  String?
  createdAt   DateTime @default(now())
}
